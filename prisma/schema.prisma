// 로컬 개발용 (SQLite - Docker 불필요)
// 프로덕션(MySQL/Aurora)은 prisma/schema.mysql.prisma 사용

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model InterviewReport {
  id               String   @id @default(uuid())
  candidateName    String   @map("candidate_name")
  position         String
  interviewDate    String   @map("interview_date")
  interviewRound   String?  @map("interview_round")
  interviewerName  String   @map("interviewer_name")
  reportAuthor     String   @default("") @map("report_author")
  tiroScript       String   @map("tiro_script")
  transcript       String?
  qnaData          String?  @map("qna_data")
  values           String?
  competencies     String?
  overall          String?
  interviewerNotes String?  @map("interviewer_notes")
  ceoDecision      String?  @map("ceo_decision")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([candidateName])
  @@index([position])
  @@index([interviewDate])
  @@map("interview_reports")
}

model RecruitmentPosition {
  id             String   @id @default(uuid())
  positionName   String   @map("position_name")
  hiringManager  String   @map("hiring_manager")
  hrPm           String   @default("") @map("hr_pm")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("recruitment_positions")
}
