// Supabase (PostgreSQL) 배포용
// 사용법: prisma generate --schema=prisma/schema.supabase.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InterviewReport {
  id               String   @id @default(uuid())
  candidateName    String   @map("candidate_name")
  position         String
  interviewDate    String   @map("interview_date")
  interviewRound   String?  @map("interview_round")
  interviewerName  String   @map("interviewer_name")
  reportAuthor     String   @default("") @map("report_author")
  tiroScript       String   @db.Text @map("tiro_script")
  transcript       String?  @db.Text
  qnaData          Json?    @map("qna_data")
  values           Json?
  competencies     Json?
  overall          Json?
  immersion        Json?
  interviewerNotes Json?    @map("interviewer_notes")
  ceoDecision      String?  @map("ceo_decision")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([candidateName])
  @@index([position])
  @@index([interviewDate])
  @@map("interview_reports")
}

model RecruitmentPosition {
  id             String   @id @default(uuid())
  positionName   String   @map("position_name")
  hiringManager  String   @map("hiring_manager")
  hrPm           String   @default("") @map("hr_pm")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("recruitment_positions")
}
